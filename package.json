{
  "name": "bootcamp-treinos-bun",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run dev:api & bun run dev:web",
    "dev:api": "bun --watch src/server/index.ts",
    "dev:web": "next dev -H 0.0.0.0 -p ${APP_PORT:-3000}",
    "build": "next build && bunx tsc --noEmit",
    "start": "next start -H 0.0.0.0 -p ${APP_PORT:-3000}",
    "start:api": "bun src/server/index.ts",
    "test": "bun test",
    "test:e2e": "playwright test",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:studio": "bunx drizzle-kit studio",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --fix",
    "format": "bunx prettier --write .",
    "check": "bunx tsc --noEmit && bunx eslint . && bunx prettier --check ."
  },
  "dependencies": {
    "@elysiajs/cors": "latest",
    "@radix-ui/react-slot": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "dayjs": "latest",
    "dotenv": "latest",
    "drizzle-orm": "latest",
    "elysia": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "pg": "latest",
    "radix-ui": "^1.4.3",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "latest",
    "@types/bun": "^1.3.13",
    "@types/node": "latest",
    "@types/pg": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "latest",
    "eslint": "9.39.2",
    "eslint-config-next": "latest",
    "prettier": "latest",
    "tailwindcss": "latest",
    "typescript": "latest"
  },
  "packageManager": "bun@1.3.11"
}
